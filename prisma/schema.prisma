model Business {
  id          String  @id @default(uuid())
  name        String
  phone       String?
  email       String?
  website     String?
  address     String?
  state       String?
  city        String?
  description String?
  postal_code String?
  country     String?

  opportunities Opportunity[]
}

model Opportunity {
  id                String  @id @default(uuid())
  name              String
  pipeline_id       String
  pipeline_stage_id String
  status            String
  monetary_value    Float?
  assigned_to       String?
  source            String?
  lost_reason       String?
  call_record_url   String?
  feedback          String?

  contact_id  String?
  contact     Contact?  @relation(fields: [contact_id], references: [id])
  business_id String?
  business    Business? @relation(fields: [business_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ==========================================
// DATA CENTER MODULE (Clay-like)
// ==========================================

// 1. Definitions / Config

model ICPProfile {
  id   String @id @default(uuid())
  name String

  targetIndustries Int[] // taxonomy_ids
  companySizeMin   Int?
  companySizeMax   Int?
  geos             String[] // country/city
  personas         Json? // titles/seniority
  exclusions       Json? // industries/titles/domains
  signalWeights    Json?
  scoringWeights   Json?

  createdBy String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imports ImportJob[]
}

model SourceConnector {
  id         String  @id @default(uuid())
  type       String // csv, apollo, salesnav, clay, webhook
  name       String
  authRef    String? // encrypted pointer
  rateLimits Json?
  status     String  @default("active")

  imports ImportJob[]
}

model Recipe {
  id           String @id @default(uuid())
  name         String
  type         String // find_people, find_companies, enrich, verify
  inputSchema  Json?
  steps        Json // pipeline steps array
  outputSchema Json?
  version      Int    @default(1)
  status       String @default("active")

  imports ImportJob[]
}

model FieldMapping {
  id          String @id @default(uuid())
  sourceType  String // csv_salesnav, apollo_api, etc
  mappingName String

  // Mapping config: { "Source Column": "canonicalField" }
  mappings    Json
  transforms  Json?
  validations Json?
}

// 2. Operational Data

model ImportJob {
  id                String           @id @default(uuid())
  sourceConnectorId String?
  sourceConnector   SourceConnector? @relation(fields: [sourceConnectorId], references: [id])

  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id])

  icpProfileId String?
  icpProfile   ICPProfile? @relation(fields: [icpProfileId], references: [id])

  providerProfileId String?
  providerProfile   ProviderProfile? @relation(fields: [providerProfileId], references: [id])

  status     String // pending, processing, completed, failed
  startedAt  DateTime?
  finishedAt DateTime?

  rowCountInput    Int @default(0)
  rowCountAccepted Int @default(0)
  rowCountRejected Int @default(0)
  rowCountEnriched Int @default(0)

  createdBy String
  createdAt DateTime @default(now())

  rows StagingRow[]
}

model StagingRow {
  id          String    @id @default(uuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id])

  rawJson        Json
  normalizedJson Json?

  dedupeKey String? // email/phone/linkedin_id/domain
  rowStatus String // new, validated, enriched, rejected, synced

  rejectionReason String?

  personId String?
  person   PersonEntity? @relation(fields: [personId], references: [id])

  companyId String?
  company   CompanyEntity? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PersonEntity {
  id String @id @default(uuid())

  // Canonical Fields
  fullName  String?
  firstName String?
  lastName  String?

  email  String? // Primary
  emails String[] // Alternates

  phone  String? // E.164 Primary
  phones String[] // Alternates

  linkedinUrl String?
  linkedinId  String?

  title      String?
  seniority  String?
  department String?

  locationCity    String?
  locationCountry String?

  languages String[]

  verificationStatus String? // verified, risky, invalid

  sourceProvider String?
  sourceRecordId String?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  // Relations
  stagingRows StagingRow[]
  companyId   String?
  company     CompanyEntity? @relation(fields: [companyId], references: [id])

  relationships  EntityRelationship[]
  signals        SignalEvent[]
  enrichmentJobs EnrichmentJob[]
  scores         Score[]
}

model CompanyEntity {
  id String @id @default(uuid())

  companyName String
  domain      String? @unique
  linkedinUrl String?
  linkedinId  String?

  industryTaxonomyId Int?
  employeeCountRange String? // 1-10, 11-50...

  locationCity    String?
  locationCountry String?

  techStack      Json?
  signalsSummary Json?

  sourceProvider String?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  // Relations
  stagingRows    StagingRow[]
  people         PersonEntity[]
  relationships  EntityRelationship[]
  signals        SignalEvent[]
  enrichmentJobs EnrichmentJob[]
  scores         Score[]
}

model EntityRelationship {
  id       String       @id @default(uuid())
  personId String
  person   PersonEntity @relation(fields: [personId], references: [id])

  companyId String
  company   CompanyEntity @relation(fields: [companyId], references: [id])

  role      String?
  title     String?
  startDate DateTime?
  endDate   DateTime?
  isCurrent Boolean   @default(true)

  confidenceScore Float?

  createdAt DateTime @default(now())
}

model EnrichmentJob {
  id String @id @default(uuid())

  entityType String // person, company
  personId   String?
  person     PersonEntity? @relation(fields: [personId], references: [id])

  companyId String?
  company   CompanyEntity? @relation(fields: [companyId], references: [id])

  provider  String // apollo, clearbit, etc
  status    String // pending, success, failed
  retries   Int    @default(0)
  costUnits Int    @default(0)

  resultJson Json?
  error      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SignalEvent {
  id String @id @default(uuid())

  entityType String // person, company
  personId   String?
  person     PersonEntity? @relation(fields: [personId], references: [id])

  companyId String?
  company   CompanyEntity? @relation(fields: [companyId], references: [id])

  type        String // job_change, funding, news
  source      String?
  evidenceUrl String?

  detectedAt  DateTime @default(now())
  impactScore Int?
  confidence  Float?

  createdAt DateTime @default(now())
}

model Score {
  id String @id @default(uuid())

  entityType String
  personId   String?
  person     PersonEntity? @relation(fields: [personId], references: [id])

  companyId String?
  company   CompanyEntity? @relation(fields: [companyId], references: [id])

  fitScore        Int @default(0)
  intentScore     Int @default(0)
  engagementScore Int @default(0)
  finalScore      Int @default(0)

  scoringVersion String   @default("1.0")
  computedAt     DateTime @default(now())
}

model AuditLog {
  id         String @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String

  changes Json? // { before: ..., after: ... }

  createdAt DateTime @default(now())
}

// ==========================================
// INTEGRATION PLATFORM (Clay-like)
// Encrypted credential storage + Waterfall enrichment
// ==========================================

model IntegrationProvider {
  id                String   @id @default(uuid())
  slug              String   @unique // "apollo", "prospeo", "lemlist", etc.
  name              String
  logoUrl           String?
  capabilities      Json     // { email: true, phone: true, company: true, linkedin: true }
  configSchema      Json?    // JSON schema for provider-specific config

  // Encrypted credentials (AES-256-GCM)
  encryptedApiKey   String?
  encryptedApiKeyIv String?  // IV for decryption

  // Provider status
  status            String   @default("inactive") // "active", "inactive", "error"
  lastTestAt        DateTime?
  lastTestStatus    String?  // "success", "failed", "rate_limited"
  lastTestMessage   String?

  // Usage tracking
  totalCreditsUsed  Int      @default(0)
  monthlyCreditsUsed Int     @default(0)
  monthlyResetAt    DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  waterfallSteps    WaterfallStep[]
  usageLogs         ProviderUsageLog[]
}

model EnrichmentWaterfall {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique // "email_waterfall", "phone_waterfall"
  enrichmentType   String   // "email" | "phone" | "company" | "linkedin"
  description      String?

  stopOnFirstMatch Boolean  @default(true)
  maxProviders     Int      @default(3) // Max providers to try before stopping
  isActive         Boolean  @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  steps            WaterfallStep[]
}

model WaterfallStep {
  id          String              @id @default(uuid())
  waterfallId String
  waterfall   EnrichmentWaterfall @relation(fields: [waterfallId], references: [id], onDelete: Cascade)

  providerId  String
  provider    IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  priority    Int                 // 0 = first, lower = higher priority
  isEnabled   Boolean             @default(true)
  config      Json?               // Step-specific config overrides

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([waterfallId, providerId])
  @@index([waterfallId, priority])
}

model ProviderUsageLog {
  id             String   @id @default(uuid())
  providerId     String
  provider       IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  requestType    String   // "email_enrich", "phone_enrich", "company_enrich", "test_connection"
  status         String   // "success", "not_found", "error", "rate_limited"

  // Request details
  inputHash      String?  // Hash of input for deduplication tracking
  creditsUsed    Int      @default(0)
  responseTimeMs Int?

  // Result summary
  resultFound    Boolean  @default(false)
  errorMessage   String?

  // Context
  waterfallId    String?
  entityType     String?  // "person", "company"
  entityId       String?

  createdAt      DateTime @default(now())

  @@index([providerId, createdAt])
  @@index([providerId, requestType])
}

// ==========================================
// WALLET & BILLING SYSTEM
// Credit management and usage policies
// ==========================================

// Workspace Wallet - رصيد كل workspace
model WorkspaceWallet {
  id                String   @id @default(uuid())
  workspaceId       String   @unique

  // Balances
  creditBalance     Float    @default(0)
  reservedCredits   Float    @default(0)  // For pending operations

  // Limits
  monthlyLimit      Float?
  dailyLimit        Float?

  // Billing
  billingCycle      String   @default("monthly") // monthly, quarterly, annual
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime?

  // Status
  status            String   @default("active") // active, suspended, exhausted

  // Relations
  transactions      WalletTransaction[]
  creditPolicies    CreditPolicy[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Wallet Transactions - سجل المعاملات
model WalletTransaction {
  id              String   @id @default(uuid())
  walletId        String
  wallet          WorkspaceWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type            String   // credit_add, credit_use, refund, adjustment, reservation, release
  amount          Float
  balanceAfter    Float

  // Context
  providerId      String?
  requestType     String?  // email_enrich, phone_enrich, etc.
  entityId        String?

  // Metadata
  description     String?
  performedBy     String?  // admin user id
  metadata        Json?    // Additional context

  createdAt       DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([walletId, type])
}

// Credit Policy - سياسة الرصيد لكل workspace
model CreditPolicy {
  id              String   @id @default(uuid())
  walletId        String
  wallet          WorkspaceWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // Provider Access
  providerSlug    String

  // Limits
  enabled         Boolean  @default(false)
  dailyLimit      Int?
  monthlyLimit    Int?
  usedToday       Int      @default(0)
  usedThisMonth   Int      @default(0)

  // Cost Override
  unitCostOverride Float?  // Override default cost

  // Features
  allowedFeatures String[] // ["email_find", "phone_find", "verify"]

  // Overage Policy
  overagePolicy   String   @default("stop") // stop, request_approval, auto_topup

  // Reset tracking
  lastDailyReset  DateTime @default(now())
  lastMonthlyReset DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([walletId, providerSlug])
  @@index([walletId])
}

// Admin Audit Log - سجل إجراءات المسؤولين
model AdminAuditLog {
  id              String   @id @default(uuid())
  adminUserId     String
  adminEmail      String?

  action          String   // provider_connected, policy_updated, credits_added, etc.
  targetType      String   // provider, workspace, policy, system
  targetId        String?

  // Details
  details         String?
  changes         Json?    // { before: ..., after: ... }
  ipAddress       String?
  userAgent       String?

  status          String   @default("success") // success, failed, warning

  createdAt       DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}
